{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${workspaceFolder}/.pixi/envs/default/python.exe",
            "cwd": "${workspaceFolder}",
            //"args": ["--create_GADM_raster", "--resolution", "6.00"],
            //"args": ["--process", "no_copy", "--ssp_baseline", "SSP2"],
            //"args": ["--downscale_population", "--scenario", "ELV-SSP2-CP", "--model", "IMAGE", "--profile", "third_round"],
            //"args": ["--downscale_gdp_ppp", "--scenario", "ELV-SSP2-CP", "--model", "IMAGE", "--profile", "second_round"],
            //"args": ["--downscale_emissions", "--scenario", "ELV-SSP2-CP", "--model", "IMAGE", "--profile", "second_round", "--emissions", "gross"],
            //"args": ["--downscale_emissions", "--scenario", "ELV-SSP2-1150F", "--model", "IMAGE", "--profile", "fifth_round"],
            "args": ["--plot", "--scenario", "ELV-SSP2-1150F", "--model", "IMAGE", "--profile", "third_round",  "--emissions", "net", "--global_min", "-0.007856", "--global_max", "0.120754"],
            //"args": ["--plot", "--scenario", "ELV-SSP2-CP", "--model", "IMAGE", "--profile", "third_round", "--emissions", "net"],
            //"args": ["--upload", "--scenario", "ELV-SSP2-CP", "--model", "IMAGE", "--profile", "second_round"],
            //"args": ["--compare"],
            "env": {
                "MPLBACKEND": "Agg",
                "PYDEVD_USE_CYTHON": "NO",
                "PYDEVD_DISABLE_FILE_VALIDATION": "1"
            }
        }
    ]
}
